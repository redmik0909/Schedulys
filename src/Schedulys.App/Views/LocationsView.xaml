<UserControl x:Class="Schedulys.App.Views.LocationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

  <Grid Margin="28,24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="300"/>
      <ColumnDefinition Width="20"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Panneau gauche : formulaire ── -->
    <StackPanel Grid.Column="0">
      <Border Style="{StaticResource Card}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="{Binding FormTitle}" Style="{StaticResource CardTitle}"/>

          <TextBlock Text="NOM" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : Gym A"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding NomInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="CAPACITÉ" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : 30"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding CapaciteInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="TYPE" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding Types}"
                    SelectedItem="{Binding SelectedType}"
                    Margin="0,0,0,16"/>

          <Button Content="{Binding AddButtonLabel}" Command="{Binding AddCommand}"
                  Style="{StaticResource BtnPrimary}"
                  HorizontalAlignment="Left" Padding="20,0"/>
        </StackPanel>
      </Border>

      <Button Content="Supprimer la sélection" Style="{StaticResource BtnDanger}"
              Command="{Binding DeleteSelectedCommand}" HorizontalAlignment="Left"/>

      <TextBlock Text="{Binding Erreur}" Foreground="{StaticResource AppDanger}"
                 FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Erreur}" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </StackPanel>

    <!-- ── Colonne droite : table ── -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Locaux" Style="{StaticResource PageTitle}" Margin="0"/>

      <DataGrid Grid.Row="2"
                ItemsSource="{Binding Salles}"
                SelectedItem="{Binding Selected}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="NOM"      Binding="{Binding Nom}"      Width="*"/>
          <DataGridTextColumn Header="CAPACITÉ" Binding="{Binding Capacite}" Width="110"/>
          <DataGridTextColumn Header="TYPE"     Binding="{Binding Type}"     Width="220"/>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</UserControl>
