<Window x:Class="Schedulys.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:Schedulys.App.Views"
        xmlns:vm="clr-namespace:Schedulys.App.ViewModels"
        Title="Schedulys"
        Height="820" Width="1380"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="Segoe UI"
        TextElement.FontSize="13"
        Background="{StaticResource AppBg}">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════════════════════════ -->
    <Border Grid.Column="0" Background="#0F172A">
      <DockPanel>

        <!-- Logo -->
        <Border DockPanel.Dock="Top" Padding="20,24,20,20">
          <StackPanel Orientation="Horizontal">
            <Border Background="#4F46E5" CornerRadius="8" Width="32" Height="32">
              <md:PackIcon Kind="CalendarClock" Width="18" Height="18"
                           Foreground="White" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
              <TextBlock Text="Schedulys" Foreground="White" FontSize="15"
                         FontWeight="SemiBold" LineHeight="18"/>
              <TextBlock Text="Gestion des examens" Foreground="#4D5D77"
                         FontSize="10" LineHeight="14"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Séparateur -->
        <Border DockPanel.Dock="Top" Height="1" Background="#1E293B" Margin="0,0,0,8"/>

        <!-- École + version en bas -->
        <Border DockPanel.Dock="Bottom" Padding="20,12" BorderThickness="0,1,0,0"
                BorderBrush="#1E293B">
          <DockPanel>
            <TextBlock DockPanel.Dock="Right" Text="v1.1" Foreground="#334155"
                       FontSize="10" VerticalAlignment="Bottom"/>
            <StackPanel>
              <TextBlock Text="{Binding License.SchoolName, FallbackValue='—'}"
                         Foreground="#94A3B8" FontSize="11" FontWeight="Medium"
                         TextTrimming="CharacterEllipsis"/>
              <TextBlock Text="Licence active" Foreground="#334155" FontSize="10"/>
            </StackPanel>
          </DockPanel>
        </Border>

        <!-- Navigation -->
        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled">
          <ListBox ItemsSource="{Binding NavItems}"
                   SelectedItem="{Binding SelectedNavItem}"
                   Background="Transparent"
                   BorderThickness="0"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                   Padding="0,4,0,4">

            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding"         Value="0"/>
                <Setter Property="Margin"          Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                      <ContentPresenter/>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
                <Style.Triggers>
                  <!-- Items header non sélectionnables -->
                  <DataTrigger Binding="{Binding IsHeader}" Value="True">
                    <Setter Property="IsEnabled"  Value="False"/>
                    <Setter Property="Focusable"  Value="False"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
              <DataTemplate>
                <Grid>
                  <!-- Label catégorie -->
                  <Border Padding="20,14,20,4">
                    <TextBlock Text="{Binding Label}" Foreground="#334155"
                               FontSize="10" FontWeight="SemiBold">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Visibility" Value="Collapsed"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                              <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Border>

                  <!-- Nav item -->
                  <Border x:Name="navItem" Margin="8,1" CornerRadius="6"
                          Background="Transparent" Padding="12,0" Height="38"
                          Cursor="Hand">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding IsHeader}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <md:PackIcon x:Name="navIcon" Kind="{Binding Icon}"
                                   Width="16" Height="16" Foreground="#475569"
                                   VerticalAlignment="Center"/>
                      <TextBlock x:Name="navLabel" Text="{Binding Label}"
                                 Foreground="#94A3B8" FontSize="13"
                                 VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                  </Border>
                </Grid>

                <DataTemplate.Triggers>
                  <!-- Sélectionné -->
                  <DataTrigger Binding="{Binding IsSelected,
                               RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                               Value="True">
                    <Setter TargetName="navItem"  Property="Background" Value="#1E3A5F"/>
                    <Setter TargetName="navIcon"  Property="Foreground" Value="White"/>
                    <Setter TargetName="navLabel" Property="Foreground" Value="White"/>
                  </DataTrigger>
                  <!-- Hover (non sélectionné) -->
                  <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                      <Condition Binding="{Binding IsMouseOver,
                                 RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                 Value="True"/>
                      <Condition Binding="{Binding IsSelected,
                                 RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                 Value="False"/>
                      <Condition Binding="{Binding IsHeader}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="navItem" Property="Background" Value="#182334"/>
                  </MultiDataTrigger>
                </DataTemplate.Triggers>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════
         ZONE PRINCIPALE
    ═══════════════════════════════════════════════════════════ -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Top bar -->
      <Border Grid.Row="0"
              Background="White"
              BorderThickness="0,0,0,1"
              BorderBrush="{StaticResource AppBorder}"
              Padding="28,0">
        <DockPanel Height="60">
          <TextBlock DockPanel.Dock="Right"
                     Text="{Binding TodayLabel}"
                     FontSize="12" Foreground="{StaticResource AppTextMuted}"
                     VerticalAlignment="Center"/>
          <TextBlock Text="{Binding CurrentSectionLabel}"
                     FontSize="17" FontWeight="SemiBold"
                     Foreground="{StaticResource AppText}"
                     VerticalAlignment="Center"/>
        </DockPanel>
      </Border>

      <!-- Contenu -->
      <Grid Grid.Row="1" Background="{StaticResource AppBg}">

        <!-- ── Dashboard ── -->
        <ScrollViewer Padding="32,28"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsDashboard, Converter={StaticResource BoolToVis}}">
          <StackPanel MaxWidth="1040">

            <!-- Stat cards -->
            <Grid Margin="0,0,0,16">
              <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
              </Grid.ColumnDefinitions>

              <!-- Enseignants -->
              <Border Grid.Column="0" Style="{StaticResource Card}"
                      Padding="0" Margin="0,0,12,0">
                <Grid>
                  <Border Width="4" HorizontalAlignment="Left"
                          Background="#4F46E5" CornerRadius="10,0,0,10"/>
                  <DockPanel Margin="22,18,18,18">
                    <md:PackIcon DockPanel.Dock="Right" Kind="AccountTie"
                                 Width="36" Height="36" Foreground="#E2E8F0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                      <TextBlock Text="{Binding StatEnseignants}" FontSize="36"
                                 FontWeight="Bold" Foreground="#4F46E5" LineHeight="40"/>
                      <TextBlock Text="Enseignants" FontSize="12"
                                 Foreground="{StaticResource AppTextSub}" Margin="0,3,0,0"/>
                    </StackPanel>
                  </DockPanel>
                </Grid>
              </Border>

              <!-- Groupes -->
              <Border Grid.Column="1" Style="{StaticResource Card}"
                      Padding="0" Margin="0,0,12,0">
                <Grid>
                  <Border Width="4" HorizontalAlignment="Left"
                          Background="#0EA5E9" CornerRadius="10,0,0,10"/>
                  <DockPanel Margin="22,18,18,18">
                    <md:PackIcon DockPanel.Dock="Right" Kind="AccountGroup"
                                 Width="36" Height="36" Foreground="#E2E8F0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                      <TextBlock Text="{Binding StatGroupes}" FontSize="36"
                                 FontWeight="Bold" Foreground="#0EA5E9" LineHeight="40"/>
                      <TextBlock Text="Groupes" FontSize="12"
                                 Foreground="{StaticResource AppTextSub}" Margin="0,3,0,0"/>
                    </StackPanel>
                  </DockPanel>
                </Grid>
              </Border>

              <!-- Locaux -->
              <Border Grid.Column="2" Style="{StaticResource Card}"
                      Padding="0" Margin="0,0,12,0">
                <Grid>
                  <Border Width="4" HorizontalAlignment="Left"
                          Background="#F59E0B" CornerRadius="10,0,0,10"/>
                  <DockPanel Margin="22,18,18,18">
                    <md:PackIcon DockPanel.Dock="Right" Kind="DoorOpen"
                                 Width="36" Height="36" Foreground="#E2E8F0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                      <TextBlock Text="{Binding StatLocaux}" FontSize="36"
                                 FontWeight="Bold" Foreground="#F59E0B" LineHeight="40"/>
                      <TextBlock Text="Locaux" FontSize="12"
                                 Foreground="{StaticResource AppTextSub}" Margin="0,3,0,0"/>
                    </StackPanel>
                  </DockPanel>
                </Grid>
              </Border>

              <!-- Épreuves -->
              <Border Grid.Column="3" Style="{StaticResource Card}" Padding="0">
                <Grid>
                  <Border Width="4" HorizontalAlignment="Left"
                          Background="#8B5CF6" CornerRadius="10,0,0,10"/>
                  <DockPanel Margin="22,18,18,18">
                    <md:PackIcon DockPanel.Dock="Right" Kind="ClipboardText"
                                 Width="36" Height="36" Foreground="#E2E8F0"
                                 VerticalAlignment="Center"/>
                    <StackPanel>
                      <TextBlock Text="{Binding StatEpreuves}" FontSize="36"
                                 FontWeight="Bold" Foreground="#8B5CF6" LineHeight="40"/>
                      <TextBlock Text="Épreuves" FontSize="12"
                                 Foreground="{StaticResource AppTextSub}" Margin="0,3,0,0"/>
                    </StackPanel>
                  </DockPanel>
                </Grid>
              </Border>
            </Grid>

            <!-- Sessions cette semaine -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,16">
              <DockPanel Margin="22,18,22,18">
                <md:PackIcon DockPanel.Dock="Right" Kind="CalendarMonth"
                             Width="48" Height="48" Foreground="#E2E8F0"
                             VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <TextBlock Text="{Binding StatCreneaux}" FontSize="36"
                             FontWeight="Bold" Foreground="#10B981" LineHeight="40"/>
                  <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="sessions d'examen" FontSize="14" FontWeight="Medium"
                               Foreground="{StaticResource AppText}"/>
                    <TextBlock Text="planifiées cette semaine" FontSize="12"
                               Foreground="{StaticResource AppTextSub}" Margin="0,2,0,0"/>
                  </StackPanel>
                </StackPanel>
              </DockPanel>
            </Border>

            <!-- Import données -->
            <Border Style="{StaticResource Card}" Padding="0">
              <DockPanel Margin="22,18,22,18">
                <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center">
                  <Button Content="Importer"
                          Style="{StaticResource BtnPrimary}"
                          Command="{Binding ImporterDonneesCommand}"
                          Padding="20,0" Height="36"/>
                  <TextBlock Text="{Binding ImportStatus}"
                             FontSize="11" Foreground="#10B981"
                             HorizontalAlignment="Center" Margin="0,8,0,0">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding ImportStatus}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                  <TextBlock Text="Données initiales" FontSize="14" FontWeight="SemiBold"
                             Foreground="{StaticResource AppText}"/>
                  <TextBlock Foreground="{StaticResource AppTextSub}"
                             FontSize="12" Margin="0,4,0,0" TextWrapping="Wrap" MaxWidth="520">
                    Importer enseignants, locaux, épreuves et sessions depuis le calendrier scolaire 2025-2026
                  </TextBlock>
                </StackPanel>
              </DockPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>

        <!-- ── Sections dynamiques ── -->
        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="horaire">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:PlanningView DataContext="{Binding Planning}" IsVisibleChanged="OnPlanningVisibleChanged"/>
        </Border>

        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="enseignants">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:TeachersView DataContext="{Binding Teachers}"/>
        </Border>

        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="groupes">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:GroupesView DataContext="{Binding Groupes}"/>
        </Border>

        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="epreuves">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:ExamsView DataContext="{Binding Exams}" IsVisibleChanged="OnExamsVisibleChanged"/>
        </Border>

        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="locaux">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:LocationsView DataContext="{Binding Locations}"/>
        </Border>

        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="exporter">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:ExportsView DataContext="{Binding Exports}"/>
        </Border>

        <Border>
          <Border.Style>
            <Style TargetType="Border">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedNavItem.Section}" Value="licence">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Border.Style>
          <views:LicenceView DataContext="{Binding}"/>
        </Border>

      </Grid>
    </Grid>
  </Grid>
</Window>
