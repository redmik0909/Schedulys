<UserControl x:Class="Schedulys.App.Views.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

  <Grid Margin="28,24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="340"/>
      <ColumnDefinition Width="20"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Panneau gauche : formulaire ── -->
    <StackPanel Grid.Column="0">
      <Border Style="{StaticResource Card}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="Ajouter une épreuve" Style="{StaticResource CardTitle}"/>

          <TextBlock Text="NOM DE L'ÉPREUVE" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : Mathématiques SN"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding NomInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="CLASSE" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding ClassesDisponibles}"
                    SelectedItem="{Binding SelectedClasse}"
                    DisplayMemberPath="Nom"
                    Margin="0,0,0,12"/>

          <TextBlock Text="DURÉE (MINUTES)" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : 90"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding DureeInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,14"/>

          <!-- Options -->
          <Border Background="{StaticResource AppHover}" CornerRadius="6"
                  Padding="12,10" Margin="0,0,0,16">
            <StackPanel>
              <CheckBox Content="Tiers-temps"
                        Style="{StaticResource MaterialDesignCheckBox}"
                        IsChecked="{Binding TiersTemps}"
                        Margin="0,0,0,6"/>
              <CheckBox Content="Épreuve ministérielle"
                        Style="{StaticResource MaterialDesignCheckBox}"
                        IsChecked="{Binding Ministerielle}"/>
            </StackPanel>
          </Border>

          <Button Content="Ajouter" Command="{Binding AddCommand}"
                  Style="{StaticResource BtnPrimary}"
                  HorizontalAlignment="Left" Padding="20,0"/>
        </StackPanel>
      </Border>

      <Button Content="Supprimer la sélection" Style="{StaticResource BtnDanger}"
              Command="{Binding DeleteSelectedCommand}" HorizontalAlignment="Left"/>

      <TextBlock Text="{Binding Erreur}" Foreground="{StaticResource AppDanger}"
                 FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Erreur}" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </StackPanel>

    <!-- ── Colonne droite : table ── -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Épreuves" Style="{StaticResource PageTitle}" Margin="0"/>

      <DataGrid Grid.Row="2"
                ItemsSource="{Binding Epreuves}"
                SelectedItem="{Binding Selected}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="ÉPREUVE" Binding="{Binding Nom}"       Width="*"/>
          <DataGridTextColumn Header="CLASSE"  Binding="{Binding ClasseNom}" Width="200"/>
          <DataGridTextColumn Header="DURÉE"   Binding="{Binding Duree}"     Width="100"/>
          <DataGridTextColumn Header="OPTIONS" Binding="{Binding Options}"   Width="200"/>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</UserControl>
