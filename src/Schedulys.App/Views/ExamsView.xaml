<UserControl x:Class="Schedulys.App.Views.ExamsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Schedulys.App.ViewModels">

  <Grid Margin="28,24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="300"/>
      <ColumnDefinition Width="20"/>
      <ColumnDefinition Width="300"/>
      <ColumnDefinition Width="16"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Colonne 1 : liste des épreuves ── -->
    <Grid Grid.Column="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0">
        <TextBlock Text="Épreuves" Style="{StaticResource PageTitle}" DockPanel.Dock="Left"/>
        <Button Content="+ Nouvelle" Command="{Binding NouvelleEpreuveCommand}"
                Style="{StaticResource BtnPrimary}"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Height="30" Padding="12,0" FontSize="11"/>
      </DockPanel>

      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding GroupedEpreuves}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:NiveauEpreuveGroup}">
              <StackPanel Margin="0,0,0,8">
                <!-- En-tête du niveau -->
                <Border Background="{StaticResource AppAccentLight}"
                        Padding="8,4" CornerRadius="4" Margin="0,0,0,4">
                  <TextBlock Text="{Binding NiveauLabel}"
                             FontSize="11" FontWeight="Bold"
                             Foreground="{StaticResource AppAccent}"/>
                </Border>
                <!-- Épreuves du niveau -->
                <ItemsControl ItemsSource="{Binding Items}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:EpreuveDisplay}">
                      <Border Margin="0,0,0,4" CornerRadius="6" Padding="10,8"
                              Cursor="Hand">
                        <Border.Style>
                          <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource AppSurface}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AppBorder}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#EEF2FF"/>
                                <Setter Property="BorderBrush" Value="#4F46E5"/>
                              </DataTrigger>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AppHover}"/>
                              </Trigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <Border.InputBindings>
                          <MouseBinding MouseAction="LeftClick"
                                        Command="{Binding DataContext.SelectCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <DockPanel>
                          <Button DockPanel.Dock="Right"
                                  Content="✕" Style="{StaticResource BtnGhost}"
                                  Height="20" Width="20" Padding="0" FontSize="10"
                                  VerticalAlignment="Top"
                                  Command="{Binding DataContext.DeleteSelectedCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"/>
                          <StackPanel>
                            <TextBlock Text="{Binding Nom}" FontWeight="Medium" FontSize="13"
                                       Foreground="{StaticResource AppText}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                              <TextBlock Text="{Binding Duree, StringFormat='{}{0} min'}"
                                         FontSize="11" Foreground="{StaticResource AppTextSub}"/>
                              <TextBlock Text=" · " FontSize="11" Foreground="{StaticResource AppTextMuted}"/>
                              <TextBlock Text="{Binding Options}"
                                         FontSize="11" Foreground="{StaticResource AppTextMuted}"/>
                            </StackPanel>
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>

    <!-- ── Colonne 2 : formulaire épreuve ── -->
    <StackPanel Grid.Column="2">
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="{Binding FormTitle}" Style="{StaticResource CardTitle}"/>

          <TextBlock Text="NOM DE L'ÉPREUVE" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : Mathématiques SN"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding NomInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="DURÉE (MINUTES)" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : 90"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding DureeInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="NIVEAU SCOLAIRE" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{x:Static vm:ExamsViewModel.NiveauxScolaires}"
                    SelectedItem="{Binding NiveauEpreuve}"
                    DisplayMemberPath="Libelle"
                    Margin="0,0,0,14"/>

          <Border Background="{StaticResource AppHover}" CornerRadius="6"
                  Padding="12,10" Margin="0,0,0,16">
            <StackPanel>
              <CheckBox Content="Tiers-temps"
                        Style="{StaticResource MaterialDesignCheckBox}"
                        IsChecked="{Binding TiersTemps}"
                        Margin="0,0,0,6"/>
              <CheckBox Content="Épreuve ministérielle"
                        Style="{StaticResource MaterialDesignCheckBox}"
                        IsChecked="{Binding Ministerielle}"/>
            </StackPanel>
          </Border>

          <Button Content="{Binding AddButtonLabel}" Command="{Binding AddCommand}"
                  Style="{StaticResource BtnPrimary}"
                  HorizontalAlignment="Stretch" Height="36"/>

          <!-- Messages -->
          <TextBlock Text="{Binding Message}" Foreground="{StaticResource AppSuccess}"
                     FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Message}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                  <DataTrigger Binding="{Binding Message}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock Text="{Binding Erreur}" Foreground="{StaticResource AppDanger}"
                     FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Erreur}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                  <DataTrigger Binding="{Binding Erreur}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- ── Colonne 3 : groupes associés ── -->
    <Grid Grid.Column="4">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0">
        <TextBlock Text="Groupes associés à l'épreuve"
                   Style="{StaticResource PageTitle}" DockPanel.Dock="Left"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                    VerticalAlignment="Center">
          <Button Content="Tout cocher" Command="{Binding ToutCocherCommand}"
                  Style="{StaticResource BtnSecondary}"
                  Height="30" Padding="10,0" FontSize="11" Margin="0,0,6,0"/>
          <Button Content="Tout décocher" Command="{Binding ToutDecocherCommand}"
                  Style="{StaticResource BtnSecondary}"
                  Height="30" Padding="10,0" FontSize="11" Margin="0,0,8,0"/>
          <Button Content="Enregistrer" Command="{Binding SaveGroupesCommand}"
                  Style="{StaticResource BtnPrimary}"
                  Height="30" Padding="14,0" FontSize="11"/>
        </StackPanel>
      </DockPanel>

      <!-- Indication si aucune épreuve sélectionnée -->
      <Border Grid.Row="2" Padding="24,32"
              Background="{StaticResource AppSurface}"
              BorderBrush="{StaticResource AppBorder}"
              BorderThickness="1" CornerRadius="10">
        <TextBlock Text="Sélectionnez une épreuve pour voir et modifier les groupes associés."
                   Foreground="{StaticResource AppTextMuted}"
                   FontSize="13" HorizontalAlignment="Center"
                   VerticalAlignment="Center" TextWrapping="Wrap"
                   TextAlignment="Center"/>
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasSelection}" Value="False">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>

      <!-- Liste des groupes avec checkboxes -->
      <Border Grid.Row="2" Padding="0">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasSelection}" Value="False">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding GroupesCheck}" Margin="4,4">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:GroupeCheckDisplay}">
                <Border Padding="8,5" CornerRadius="4">
                  <Border.Style>
                    <Style TargetType="Border">
                      <Setter Property="Background" Value="Transparent"/>
                      <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                          <Setter Property="Background" Value="{StaticResource AppHover}"/>
                        </Trigger>
                      </Style.Triggers>
                    </Style>
                  </Border.Style>
                  <CheckBox IsChecked="{Binding IsChecked, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource MaterialDesignCheckBox}">
                    <TextBlock Text="{Binding Label}" FontFamily="Consolas" FontSize="12"/>
                  </CheckBox>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

    </Grid>
  </Grid>
</UserControl>
