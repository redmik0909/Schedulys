<UserControl x:Class="Schedulys.App.Views.LicenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

  <ScrollViewer Margin="28,24" VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="620" HorizontalAlignment="Left">

      <TextBlock Text="Licence" Style="{StaticResource PageTitle}"/>

      <!-- Carte licence principale -->
      <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,16">
        <Grid>
          <!-- Bandeau accent top -->
          <Border Height="4" VerticalAlignment="Top" Background="{StaticResource AppAccent}"
                  CornerRadius="10,10,0,0"/>

          <Grid Margin="24,22,24,22">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Infos licence -->
            <StackPanel Grid.Column="0">

              <!-- Icône + nom école -->
              <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Border Background="{StaticResource AppAccentLight}" CornerRadius="10"
                        Width="44" Height="44">
                  <md:PackIcon Kind="School" Width="22" Height="22"
                               Foreground="{StaticResource AppAccent}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                  <TextBlock Text="{Binding License.SchoolName}"
                             FontSize="18" FontWeight="SemiBold"
                             Foreground="{StaticResource AppText}"/>
                  <TextBlock Text="Titulaire de la licence" FontSize="11"
                             Foreground="{StaticResource AppTextSub}"/>
                </StackPanel>
              </StackPanel>

              <!-- Séparateur -->
              <Border Height="1" Background="{StaticResource AppBorder}" Margin="0,0,0,16"/>

              <!-- Détails -->
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition/>
                  <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                  <TextBlock Text="EXPIRATION" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                  <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="CalendarCheck" Width="14" Height="14"
                                 Foreground="{StaticResource AppTextSub}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Margin="6,0,0,0" FontSize="13" FontWeight="Medium"
                               Foreground="{StaticResource AppText}">
                      <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0:d MMMM yyyy}">
                          <Binding Path="License.ExpiresAt"/>
                        </MultiBinding>
                      </TextBlock.Text>
                    </TextBlock>
                  </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                  <TextBlock Text="ID POSTE" Style="{StaticResource FieldLabel}" Margin="0,0,0,4"/>
                  <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Monitor" Width="14" Height="14"
                                 Foreground="{StaticResource AppTextSub}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding MachineId}" Margin="6,0,0,0"
                               FontSize="12" FontFamily="Consolas"
                               Foreground="{StaticResource AppTextSub}"/>
                  </StackPanel>
                </StackPanel>
              </Grid>

              <!-- Badge statut -->
              <Border HorizontalAlignment="Left" CornerRadius="20" Padding="12,5">
                <Border.Style>
                  <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource AppSuccessLight}"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding LicenceExpireBientot}" Value="True">
                        <Setter Property="Background" Value="{StaticResource AppWarningLight}"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                  <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Ellipse.Style>
                      <Style TargetType="Ellipse">
                        <Setter Property="Fill" Value="{StaticResource AppSuccess}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding LicenceExpireBientot}" Value="True">
                            <Setter Property="Fill" Value="{StaticResource AppWarning}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Ellipse.Style>
                  </Ellipse>
                  <TextBlock FontSize="12" FontWeight="Medium">
                    <TextBlock.Style>
                      <Style TargetType="TextBlock">
                        <Setter Property="Text"       Value="Licence active"/>
                        <Setter Property="Foreground" Value="{StaticResource AppSuccess}"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding LicenceExpireBientot}" Value="True">
                            <Setter Property="Text" Value="Expire dans moins de 30 jours"/>
                            <Setter Property="Foreground" Value="{StaticResource AppWarning}"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>
              </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
              <Button Content="Renouveler" Command="{Binding RenouvelerCommand}"
                      Style="{StaticResource BtnPrimary}"
                      Padding="24,0" Height="38" Margin="0,0,0,8"/>
              <Button Content="Changer de clé" Command="{Binding ChangerCleCommand}"
                      Style="{StaticResource BtnSecondary}" HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>

      <!-- Diagnostic DB -->
      <Border Style="{StaticResource Card}" Margin="0,0,0,16">
        <DockPanel>
          <md:PackIcon DockPanel.Dock="Left" Kind="DatabaseSearch" Width="20" Height="20"
                       Foreground="{StaticResource AppAccent}" VerticalAlignment="Center"/>
          <Button DockPanel.Dock="Right" Content="Rapport" Command="{Binding DiagnosticCommand}"
                  Style="{StaticResource BtnSecondary}" VerticalAlignment="Center"/>
          <StackPanel Margin="14,0,12,0">
            <TextBlock Text="Diagnostic base de données" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource AppText}"/>
            <TextBlock Text="Affiche les compteurs bruts de la base de données locale."
                       FontSize="12" Foreground="{StaticResource AppTextSub}" Margin="0,3,0,0"/>
          </StackPanel>
        </DockPanel>
      </Border>

      <!-- Support -->
      <Border Style="{StaticResource Card}">
        <DockPanel>
          <md:PackIcon DockPanel.Dock="Left" Kind="Headset" Width="20" Height="20"
                       Foreground="{StaticResource AppAccent}" VerticalAlignment="Center"/>
          <StackPanel Margin="14,0,0,0">
            <TextBlock Text="Besoin d'aide ?" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource AppText}"/>
            <TextBlock FontSize="12" Foreground="{StaticResource AppTextSub}" Margin="0,3,0,0">
              Renouvellement et support : <Run Foreground="{StaticResource AppAccent}"
                                              FontWeight="Medium">support@revolvittech.com</Run>
            </TextBlock>
          </StackPanel>
        </DockPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
