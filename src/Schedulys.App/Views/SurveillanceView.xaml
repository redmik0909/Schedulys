<UserControl x:Class="Schedulys.App.Views.SurveillanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Schedulys.App.ViewModels">

  <Grid Margin="28,24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="320"/>
      <ColumnDefinition Width="20"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Colonne gauche : formulaire ── -->
    <StackPanel Grid.Column="0">
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Assigner un rôle" Style="{StaticResource CardTitle}"/>

          <TextBlock Text="SESSION" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding SessionsDisponibles}"
                    SelectedItem="{Binding SessionSelectionnee}"
                    DisplayMemberPath="Label"
                    md:HintAssist.Hint="— sélectionner —"
                    Margin="0,0,0,12"/>

          <TextBlock Text="TYPE DE RÔLE" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{x:Static vm:SurveillanceViewModel.TypesRole}"
                    SelectedItem="{Binding TypeRoleInput}"
                    Margin="0,0,0,12"/>

          <TextBlock Text="SURVEILLANT" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding ProfsDisponibles}"
                    SelectedItem="{Binding SurveillantSelectionne}"
                    DisplayMemberPath="Nom"
                    md:HintAssist.Hint="— sélectionner —"
                    Margin="0,0,0,12"/>

          <TextBlock Text="LOCAL (OPTIONNEL)" Style="{StaticResource FieldLabel}"/>
          <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   md:HintAssist.Hint="Ex : 102"
                   Text="{Binding LocalInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="DURÉE (MINUTES)" Style="{StaticResource FieldLabel}"/>
          <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   md:HintAssist.Hint="Ex : 90"
                   Text="{Binding DureeInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,16"/>

          <Button Content="Ajouter" Command="{Binding AjouterRoleCommand}"
                  Style="{StaticResource BtnPrimary}"
                  HorizontalAlignment="Stretch" Height="36"/>

          <TextBlock Text="{Binding Message}" Foreground="{StaticResource AppSuccess}"
                     FontSize="12" Margin="0,10,0,0" TextWrapping="Wrap">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Message}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                  <DataTrigger Binding="{Binding Message}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <TextBlock Text="{Binding Erreur}" Foreground="{StaticResource AppDanger}"
                     FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Erreur}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                  <DataTrigger Binding="{Binding Erreur}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>
    </StackPanel>

    <!-- ── Colonne droite : liste par session ── -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0">
        <TextBlock Text="Rôles assignés" Style="{StaticResource PageTitle}" DockPanel.Dock="Left"/>
        <Button Content="Actualiser" Command="{Binding RefreshCommand}"
                Style="{StaticResource BtnSecondary}" DockPanel.Dock="Right"
                Height="30" Padding="12,0" FontSize="11" VerticalAlignment="Center"/>
      </DockPanel>

      <!-- Liste groupée par session -->
      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding GroupesParSession}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:SessionSurveillanceGroup}">
              <StackPanel Margin="0,0,0,16">

                <Border Background="{StaticResource AppAccentLight}"
                        Padding="12,6" CornerRadius="6" Margin="0,0,0,6">
                  <TextBlock Text="{Binding EnTete}"
                             FontSize="12" FontWeight="SemiBold"
                             Foreground="{StaticResource AppAccent}"/>
                </Border>

                <ItemsControl ItemsSource="{Binding Roles}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:RoleSurveillanceRow}">
                      <Border Margin="0,0,0,4" CornerRadius="6" Padding="12,9"
                              Background="{StaticResource AppSurface}"
                              BorderBrush="{StaticResource AppBorder}"
                              BorderThickness="1">
                        <DockPanel>
                          <Button DockPanel.Dock="Right"
                                  Content="✕" Style="{StaticResource BtnGhost}"
                                  Height="22" Width="22" Padding="0" FontSize="10"
                                  VerticalAlignment="Center"
                                  Command="{Binding DataContext.SupprimerRoleCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  CommandParameter="{Binding}"/>
                          <StackPanel>
                            <TextBlock Text="{Binding Ligne1}"
                                       FontWeight="Medium" FontSize="13"
                                       Foreground="{StaticResource AppText}"/>
                            <TextBlock Text="{Binding Ligne2}"
                                       FontSize="11" Foreground="{StaticResource AppTextSub}"
                                       Margin="0,2,0,0"/>
                          </StackPanel>
                        </DockPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- État vide -->
      <Border Grid.Row="2" Padding="32,48"
              Background="{StaticResource AppSurface}"
              BorderBrush="{StaticResource AppBorder}"
              BorderThickness="1" CornerRadius="10">
        <TextBlock Text="Aucun rôle de surveillance assigné pour le moment."
                   Foreground="{StaticResource AppTextMuted}"
                   FontSize="14" HorizontalAlignment="Center"
                   VerticalAlignment="Center" TextAlignment="Center"/>
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding GroupesParSession.Count}" Value="0">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>

    </Grid>
  </Grid>
</UserControl>
