<Window x:Class="Schedulys.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Schedulys.App.Views"
        Title="Schedulys"
        Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI" FontSize="14">

  <DockPanel>

    <!-- App bar -->
    <Border DockPanel.Dock="Top"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="20,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="12"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="🗓️" FontSize="16" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="2" Text="Schedulys"
                   FontWeight="SemiBold" FontSize="20" VerticalAlignment="Center"/>
        <TextBlock Grid.Column="3" Text="{Binding TodayLabel}"
                   FontSize="12" Foreground="{StaticResource MutedBrush}"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- Navigation par onglets -->
    <TabControl>

      <!-- Dashboard -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="▣" Margin="0,0,6,0"/>
            <TextBlock Text="Dashboard"/>
          </StackPanel>
        </TabItem.Header>
        <StackPanel>
          <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold" Margin="0,0,0,16"/>
          <UniformGrid Rows="1" Columns="4">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0">
              <StackPanel>
                <TextBlock Text="Enseignants" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                <TextBlock Text="—" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0">
              <StackPanel>
                <TextBlock Text="Groupes" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                <TextBlock Text="—" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0">
              <StackPanel>
                <TextBlock Text="Locaux" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                <TextBlock Text="—" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="Séances planifiées" Foreground="{StaticResource MutedBrush}" FontSize="13"/>
                <TextBlock Text="—" FontSize="28" FontWeight="Bold"/>
              </StackPanel>
            </Border>
          </UniformGrid>
        </StackPanel>
      </TabItem>

      <!-- Horaire -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="🗂️" Margin="0,0,6,0"/>
            <TextBlock Text="Horaire"/>
          </StackPanel>
        </TabItem.Header>
        <views:PlanningView/>
      </TabItem>

      <!-- Enseignants -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="👩‍🏫" Margin="0,0,6,0"/>
            <TextBlock Text="Enseignants"/>
          </StackPanel>
        </TabItem.Header>
        <views:TeachersView DataContext="{Binding Teachers}"/>
      </TabItem>

      <!-- Groupes -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="📚" Margin="0,0,6,0"/>
            <TextBlock Text="Groupes"/>
          </StackPanel>
        </TabItem.Header>
        <views:GroupesView DataContext="{Binding Groupes}"/>
      </TabItem>

      <!-- Locaux -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="📍" Margin="0,0,6,0"/>
            <TextBlock Text="Locaux"/>
          </StackPanel>
        </TabItem.Header>
        <views:LocationsView DataContext="{Binding Locations}"/>
      </TabItem>

      <!-- Exporter -->
      <TabItem>
        <TabItem.Header>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="⬇️" Margin="0,0,6,0"/>
            <TextBlock Text="Exporter"/>
          </StackPanel>
        </TabItem.Header>
        <views:ExportsView/>
      </TabItem>

    </TabControl>
  </DockPanel>
</Window>
