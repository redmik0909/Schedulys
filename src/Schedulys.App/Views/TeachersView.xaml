<UserControl x:Class="Schedulys.App.Views.TeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

  <Grid Margin="24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Titre -->
    <TextBlock Grid.Row="0" Text="Enseignants"
               Style="{StaticResource MaterialDesignHeadline5TextBlock}"/>

    <!-- Formulaire d'ajout -->
    <md:Card Grid.Row="2" Padding="20" UniformCornerRadius="8">
      <StackPanel>
        <TextBlock Text="Ajouter un enseignant"
                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                   Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal">
          <TextBox md:HintAssist.Hint="Nom complet"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding NomInput, UpdateSourceTrigger=PropertyChanged}"
                   Width="300" Margin="0,0,16,0"/>
          <ComboBox md:HintAssist.Hint="Rôle"
                    Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding Roles}"
                    SelectedItem="{Binding SelectedRole}"
                    Width="180" Margin="0,0,16,0"/>
          <Button Content="AJOUTER"
                  Style="{StaticResource MaterialDesignRaisedButton}"
                  Command="{Binding AddCommand}"
                  VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>
    </md:Card>

    <!-- DataGrid -->
    <DataGrid Grid.Row="4"
              ItemsSource="{Binding Profs}"
              SelectedItem="{Binding Selected}"
              Style="{StaticResource MaterialDesignDataGrid}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True"
              SelectionMode="Single">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Nom"  Binding="{Binding Nom}"  Width="*"/>
        <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="220"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Supprimer -->
    <Button Grid.Row="6"
            Content="SUPPRIMER LA SÉLECTION"
            Style="{StaticResource MaterialDesignOutlinedButton}"
            Command="{Binding DeleteSelectedCommand}"
            HorizontalAlignment="Left"/>
  </Grid>
</UserControl>
