<UserControl x:Class="Schedulys.App.Views.TeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

  <Grid Margin="24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="12"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Personnel"
               Style="{StaticResource MaterialDesignHeadline5TextBlock}"/>

    <!-- Formulaire d'ajout -->
    <md:Card Grid.Row="2" Padding="20" UniformCornerRadius="8">
      <StackPanel>
        <TextBlock Text="Ajouter un membre du personnel"
                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                   Margin="0,0,0,16"/>
        <StackPanel Orientation="Horizontal">
          <TextBox md:HintAssist.Hint="Nom complet"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding NomInput, UpdateSourceTrigger=PropertyChanged}"
                   Width="280" Margin="0,0,12,0"/>
          <ComboBox md:HintAssist.Hint="Rôle"
                    Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding Roles}"
                    SelectedItem="{Binding SelectedRole}"
                    Width="180" Margin="0,0,12,0"/>
          <TextBox md:HintAssist.Hint="Min/jour cibles"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding MinutesInput, UpdateSourceTrigger=PropertyChanged}"
                   md:HintAssist.HelperText="De la tâche éducative"
                   Width="130" Margin="0,0,12,0"/>
          <Button Content="AJOUTER"
                  Style="{StaticResource MaterialDesignRaisedButton}"
                  Command="{Binding AddCommand}"
                  VerticalAlignment="Center"/>
        </StackPanel>
      </StackPanel>
    </md:Card>

    <!-- Grille du personnel -->
    <DataGrid Grid.Row="4"
              ItemsSource="{Binding Profs}"
              SelectedItem="{Binding Selected}"
              Style="{StaticResource MaterialDesignDataGrid}"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              IsReadOnly="True"
              SelectionMode="Single">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Nom"         Binding="{Binding Nom}"          Width="*"/>
        <DataGridTextColumn Header="Rôle"        Binding="{Binding Role}"         Width="180"/>
        <DataGridTextColumn Header="Min/jour"    Binding="{Binding MinutesLabel}" Width="100"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Message erreur -->
    <TextBlock Grid.Row="5" Foreground="#D32F2F"
               Text="{Binding Erreur}" FontSize="12" Margin="0,4,0,0">
      <TextBlock.Style>
        <Style TargetType="TextBlock">
          <Setter Property="Visibility" Value="Visible"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding Erreur}" Value="">
              <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </TextBlock.Style>
    </TextBlock>

    <!-- Actions bas de page -->
    <DockPanel Grid.Row="6">
      <!-- Modifier les minutes de la sélection -->
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <TextBox md:HintAssist.Hint="Min/jour"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 Text="{Binding MinutesEditInput, UpdateSourceTrigger=PropertyChanged}"
                 Width="100" Margin="0,0,8,0"
                 IsEnabled="{Binding HasSelection}"/>
        <Button Content="ENREGISTRER MINUTES"
                Style="{StaticResource MaterialDesignOutlinedButton}"
                Command="{Binding SaveMinutesCommand}"
                VerticalAlignment="Center"/>
      </StackPanel>

      <Button DockPanel.Dock="Left"
              Content="SUPPRIMER LA SÉLECTION"
              Style="{StaticResource MaterialDesignOutlinedButton}"
              Command="{Binding DeleteSelectedCommand}"/>
    </DockPanel>
  </Grid>
</UserControl>
