<UserControl x:Class="Schedulys.App.Views.TeachersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

  <Grid Margin="28,24">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="300"/>
      <ColumnDefinition Width="20"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ── Panneau gauche ── -->
    <StackPanel Grid.Column="0">

      <!-- Formulaire ajout -->
      <Border Style="{StaticResource Card}" Margin="0,0,0,12">
        <StackPanel>
          <TextBlock Text="{Binding FormTitle}" Style="{StaticResource CardTitle}"/>

          <TextBlock Text="NOM COMPLET" Style="{StaticResource FieldLabel}"/>
          <TextBox md:HintAssist.Hint="Ex : Marie Tremblay"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding NomInput, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,10"/>

          <TextBlock Text="RÔLE" Style="{StaticResource FieldLabel}"/>
          <ComboBox Style="{StaticResource MaterialDesignOutlinedComboBox}"
                    ItemsSource="{Binding Roles}"
                    SelectedItem="{Binding SelectedRole}"
                    Margin="0,0,0,10"/>

          <StackPanel>
            <StackPanel.Style>
              <Style TargetType="StackPanel">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasSelection}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </StackPanel.Style>
            <TextBlock Text="MINUTES / JOUR (MOYENNE)" Style="{StaticResource FieldLabel}"/>
            <TextBox md:HintAssist.Hint="Ex : 90"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Text="{Binding MinutesInput, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,14"/>
          </StackPanel>
          <!-- Spacer en mode édition -->
          <Border Height="14">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding HasSelection}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
          </Border>

          <Button Content="{Binding AddButtonLabel}" Command="{Binding AddCommand}"
                  Style="{StaticResource BtnPrimary}"
                  HorizontalAlignment="Left" Padding="20,0"/>
        </StackPanel>
      </Border>

      <!-- Minutes par jour du cycle -->
      <Border Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="Minutes par jour du cycle" Style="{StaticResource CardTitle}"/>

          <!-- Placeholder -->
          <TextBlock Text="Sélectionnez un enseignant."
                     FontSize="12" Foreground="{StaticResource AppTextMuted}">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Selected}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

          <!-- Grille jours 0–9 -->
          <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding QuotasParJour}">
            <ItemsControl.Style>
              <Style TargetType="ItemsControl">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Selected}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </ItemsControl.Style>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,3">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Label}"
                             FontSize="12" Foreground="{StaticResource AppTextSub}"
                             VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1"
                           Style="{StaticResource MaterialDesignOutlinedTextBox}"
                           Text="{Binding MinutesInput, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          </ScrollViewer>

          <!-- Boutons -->
          <DockPanel Margin="0,10,0,0">
            <Button DockPanel.Dock="Right" Content="Enregistrer"
                    Style="{StaticResource BtnPrimary}"
                    Command="{Binding SaveAllQuotasCommand}"
                    Padding="16,0"/>
            <Button Content="Supprimer"
                    Style="{StaticResource BtnDanger}"
                    Command="{Binding DeleteSelectedCommand}"/>
          </DockPanel>

          <!-- Erreur -->
          <TextBlock Text="{Binding Erreur}" Foreground="{StaticResource AppDanger}"
                     FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Visible"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Erreur}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding Erreur}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>

        </StackPanel>
      </Border>

    </StackPanel>

    <!-- ── Colonne droite : table ── -->
    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <DockPanel Grid.Row="0">
        <TextBlock Text="Personnel" Style="{StaticResource PageTitle}" DockPanel.Dock="Left"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding ImportMessage}" FontSize="12" Foreground="{StaticResource AppSuccess}"
                     VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ImportMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                  <DataTrigger Binding="{Binding ImportMessage}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
          <Button Content="Importer depuis HTML" Style="{StaticResource BtnSecondary}"
                  Command="{Binding ImporterHtmlCommand}"
                  Padding="14,0" Height="34"/>
        </StackPanel>
      </DockPanel>

      <DataGrid Grid.Row="2"
                ItemsSource="{Binding Profs}"
                SelectedItem="{Binding Selected}">
        <DataGrid.Columns>
          <DataGridTextColumn Header="NOM"      Binding="{Binding Nom}"          Width="*"/>
          <DataGridTextColumn Header="RÔLE"     Binding="{Binding Role}"         Width="200"/>
          <DataGridTextColumn Header="MOY/JOUR" Binding="{Binding MinutesLabel}" Width="110"/>
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</UserControl>
