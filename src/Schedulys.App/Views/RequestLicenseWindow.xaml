<Window x:Class="Schedulys.App.Views.RequestLicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Demander une licence"
        Width="480" MinHeight="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow"
        Background="{StaticResource AppBg}">

  <Border Margin="36,28">
    <StackPanel>

      <!-- Header -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
        <Border Background="{StaticResource AppAccentLight}" CornerRadius="10"
                Width="42" Height="42">
          <md:PackIcon Kind="EmailOutline" Width="20" Height="20"
                       Foreground="{StaticResource AppAccent}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="Demander une licence" FontSize="16" FontWeight="SemiBold"
                     Foreground="{StaticResource AppText}"/>
          <TextBlock Text="Remplissez le formulaire — vous recevrez votre clé par courriel."
                     FontSize="12" Foreground="{StaticResource AppTextSub}" Margin="0,2,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- Formulaire -->
      <Grid>
        <Grid.Style>
          <Style TargetType="Grid">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Done}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Grid.Style>
        <StackPanel>
          <TextBlock Text="NOM DE L'ÉCOLE" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
          <TextBox md:HintAssist.Hint="Ex : École Montcalm"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding SchoolName, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="NOM DU CONTACT" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
          <TextBox md:HintAssist.Hint="Prénom Nom"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding ContactName, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,12"/>

          <TextBlock Text="ADRESSE COURRIEL" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
          <TextBox md:HintAssist.Hint="prenom.nom@csxx.qc.ca"
                   Style="{StaticResource MaterialDesignOutlinedTextBox}"
                   Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,16"/>

          <!-- Machine ID (info) -->
          <Border Background="{StaticResource AppHover}" CornerRadius="6" Padding="10,7" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
              <md:PackIcon Kind="Laptop" Foreground="{StaticResource AppTextMuted}"
                           Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
              <TextBlock FontSize="11" Foreground="{StaticResource AppTextMuted}" VerticalAlignment="Center">
                <Run Text="ID machine : "/>
                <Run Text="{Binding MachineId, Mode=OneWay}" FontFamily="Consolas"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Bouton + statut -->
          <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Left" Content="Envoyer la demande"
                    Style="{StaticResource BtnPrimary}"
                    Command="{Binding SendCommand}"
                    Padding="20,0" Height="38"/>
            <TextBlock Text="{Binding Status}" Margin="12,0,0,0"
                       VerticalAlignment="Center" FontSize="12"
                       Foreground="{StaticResource AppAccent}">
              <TextBlock.Style>
                <Style TargetType="TextBlock">
                  <Setter Property="Visibility" Value="Visible"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Status}" Value="">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </DockPanel>

          <!-- Erreur -->
          <Border Background="{StaticResource AppDangerLight}" CornerRadius="6"
                  Padding="10,7">
            <TextBlock Text="{Binding Erreur}" Foreground="{StaticResource AppDanger}"
                       FontSize="12" TextWrapping="Wrap"/>
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Erreur}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
          </Border>
        </StackPanel>
      </Grid>

      <!-- Confirmation envoyée -->
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding Done}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <Border Background="{StaticResource AppSuccessLight}" CornerRadius="50"
                Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,16">
          <md:PackIcon Kind="Check" Width="32" Height="32"
                       Foreground="{StaticResource AppSuccess}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="Demande envoyée !" FontSize="16" FontWeight="SemiBold"
                   Foreground="{StaticResource AppText}" HorizontalAlignment="Center"/>
        <TextBlock Text="Vous recevrez votre clé de licence par courriel sous 24&#160;h."
                   FontSize="12" Foreground="{StaticResource AppTextSub}"
                   HorizontalAlignment="Center" TextAlignment="Center"
                   Margin="0,6,0,24" TextWrapping="Wrap"/>
        <Button Content="Fermer" Style="{StaticResource BtnPrimary}"
                HorizontalAlignment="Center" Padding="28,0" Height="36"
                Click="CloseButton_Click"/>
      </StackPanel>

    </StackPanel>
  </Border>
</Window>
